{
  "name": "pii-json-checker",
  "displayName": "PII JSON Checker",
  "description": "Detects potential PII fields (first name, last name) in JSON and .NET files and shows inline warnings like SonarQube",
  "version": "0.1.0",
  "publisher": "your-publisher-id",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Linters"],
  "activationEvents": [
    "onLanguage:json",
    "onLanguage:jsonc",
    "onLanguage:csharp",
    "onLanguage:vb",
    "onLanguage:razor",
    "onLanguage:aspnetcorerazor",
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "PII JSON Checker",
      "properties": {
        "piiJsonChecker.patterns": {
          "type": "array",
          "default": [
            "first_name", "firstname", "first name",
            "last_name", "lastname", "last name",
            "firstName", "lastName"
          ],
          "description": "List of JSON key patterns to flag as potential PII"
        },
        "piiJsonChecker.severity": {
          "type": "string",
          "default": "Warning",
          "enum": ["Error", "Warning", "Information", "Hint"],
          "description": "Severity level for PII diagnostics"
        },
        "piiJsonChecker.enableLoggingDetection": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable PII detection in logging statements"
        },
        "piiJsonChecker.loggingFunctions": {
          "type": "array",
          "default": [],
          "description": "Additional logging function names to detect (e.g. ['myLogger.log'])"
        },
        "piiJsonChecker.maskingPatterns": {
          "type": "array",
          "default": [],
          "description": "Additional masking method patterns (e.g. ['.sanitize('])"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
